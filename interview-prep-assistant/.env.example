# Groq API key — get yours at https://console.groq.com
GROQ_API_KEY=

# Serper API key for web search — https://serper.dev
SERPER_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# PostgreSQL (needed for peer comparison + progress tracker)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/interview_prep

# App
SECRET_KEY=your-secret-key-here
DEBUG=true
